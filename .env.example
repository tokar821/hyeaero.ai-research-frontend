NEXT_PUBLIC_API_URL=

# Optional: server-side URL for admin proxies (defaults to NEXT_PUBLIC_API_URL).
# INTERNAL_API_URL=http://localhost:8000

# Optional: only if you use Next.js server routes under app/api/admin/* that proxy with a static key.
# Must match backend CONSULTANT_ANALYTICS_ADMIN_KEY. The /admin/queries page calls FastAPI with your login JWT instead.
# CONSULTANT_ANALYTICS_ADMIN_KEY=

# Browser → FastAPI consultant timeout (ms). Default 180000.
# NEXT_PUBLIC_RAG_TIMEOUT_MS=180000

# Legacy Next.js proxy /api/chat only (if you still use it):
# CHAT_PROXY_TIMEOUT_MS=120000