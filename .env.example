NEXT_PUBLIC_API_URL=

# Optional: server-side URL for admin proxies (defaults to NEXT_PUBLIC_API_URL).
# INTERNAL_API_URL=http://localhost:8000

# Optional: only if you use Next.js server routes under app/api/admin/* that proxy with a static key.
# Must match backend CONSULTANT_ANALYTICS_ADMIN_KEY. The /admin/queries page calls FastAPI with your login JWT instead.
# CONSULTANT_ANALYTICS_ADMIN_KEY=

# Browser → FastAPI consultant wall-clock (ms). Default 1_800_000 (30 min) if unset — slow networks / long RAG.
# Cap 7_200_000 (2h). Set 0 / off / never / false to disable client abort (wait until browser/OS closes the connection).
# NEXT_PUBLIC_RAG_TIMEOUT_MS=1800000
#
# SSE only: abort if no bytes for this long after the first chunk (stalled stream). Default 1_200_000 (20 min). 0 = off.
# NEXT_PUBLIC_RAG_STREAM_IDLE_MS=1200000

# Legacy Next.js proxy /api/chat only (if you still use it). Same semantics as NEXT_PUBLIC_RAG_TIMEOUT_MS; default 30 min.
# CHAT_PROXY_TIMEOUT_MS=1800000